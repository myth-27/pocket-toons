  {
    "path": "data\\raw\\panels\\unordinary\\ep_9\\unordinary_ep9_p033.jpg",
    "text": "ABILITY GAUGE\nMeasures from 1-10\nScore of 5+ gets a prize?\nS10\nABILITY GAUGE\nMeasuresl from 1-10\nScore of 5+ gets a prizel"
  },
  {
    "path": "data\\raw\\panels\\unordinary\\ep_9\\unordinary_ep9_p034.jpg",
    "text": "Hey, Sera:\nLook' It's an ability gauge:\nWanna give it a try?\nFoinT"
